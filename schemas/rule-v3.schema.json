{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg-db.local/schemas/rule-v3.schema.json",
  "title": "Rule V3",
  "description": "Canonical English rule families for catalog schema v3.",
  "type": "object",
  "definitions": {
    "condition": {
      "$ref": "condition-v3.schema.json"
    },
    "modifyRule": {
      "type": "object",
      "required": ["rule_id"],
      "properties": {
        "rule_id": { "type": "string", "minLength": 1 },
        "message": { "type": "string" },
        "when": { "$ref": "#/$defs/condition" },
        "target": { "type": "string" },
        "op": { "type": "string", "enum": ["add", "subtract", "multiply", "divide", "set", "min", "max"] },
        "value": {},
        "formula": {},
        "tillat": {}
      },
      "additionalProperties": false
    },
    "requireRule": {
      "type": "object",
      "required": ["rule_id"],
      "properties": {
        "rule_id": { "type": "string", "minLength": 1 },
        "message": { "type": "string" },
        "when": { "$ref": "#/$defs/condition" },
        "value": {},
        "on_fail": {},
        "on_pass": {},
        "utrustning_typ": { "type": "array", "items": { "type": "string" } },
        "utrustning_kvalitet": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "conflictRule": {
      "type": "object",
      "required": ["rule_id"],
      "properties": {
        "rule_id": { "type": "string", "minLength": 1 },
        "message": { "type": "string" },
        "when": { "$ref": "#/$defs/condition" },
        "name": { "oneOf": [{ "type": "string" }, { "type": "array", "items": { "type": "string" } }] },
        "op": { "type": "string", "enum": ["add", "subtract", "multiply", "divide", "set", "min", "max"] },
        "value": {},
        "utrustning_typ": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "grantRule": {
      "type": "object",
      "required": ["rule_id"],
      "properties": {
        "rule_id": { "type": "string", "minLength": 1 },
        "message": { "type": "string" },
        "when": { "$ref": "#/$defs/condition" },
        "target": { "type": "string" },
        "op": { "type": "string", "enum": ["add", "subtract", "multiply", "divide", "set", "min", "max"] },
        "value": {},
        "formula": {},
        "name": { "type": "string" },
        "id": { "type": "string" },
        "beviljad_niva": { "type": "string" },
        "foremal": {},
        "daler": {},
        "gratis": {},
        "gratis_upp_till": {},
        "ignore_limits": {}
      },
      "additionalProperties": false
    },
    "choiceRule": {
      "type": "object",
      "required": ["rule_id", "field"],
      "properties": {
        "rule_id": { "type": "string", "minLength": 1 },
        "when": { "$ref": "#/$defs/condition" },
        "field": { "type": "string" },
        "search": { "type": "boolean" },
        "subtitle": { "type": "string" },
        "title": { "type": "string" },
        "duplicate_policy": { "type": "string", "enum": ["allow", "reject", "confirm", "replace_existing"] },
        "exclude_used": { "type": "boolean" },
        "options": {
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "properties": {
                  "value": {},
                  "label": { "type": "string" },
                  "search": { "type": "string" },
                  "effects": { "type": "object" },
                  "rules": {
                    "type": "object",
                    "properties": {
                      "modify": { "type": "array", "items": { "$ref": "#/$defs/modifyRule" } },
                      "require": { "type": "array", "items": { "$ref": "#/$defs/requireRule" } },
                      "conflict": { "type": "array", "items": { "$ref": "#/$defs/conflictRule" } },
                      "grant": { "type": "array", "items": { "$ref": "#/$defs/grantRule" } },
                      "choice": { "type": "array", "items": { "$ref": "#/$defs/choiceRule" } }
                    },
                    "additionalProperties": false
                  }
                },
                "additionalProperties": true
              }
            ]
          }
        },
        "source": {
          "type": "object",
          "properties": {
            "types": {
              "oneOf": [
                { "type": "string" },
                { "type": "array", "items": { "type": "string" } }
              ]
            },
            "when": { "$ref": "#/$defs/condition" },
            "sort": { "type": "string" },
            "field": { "type": "string" },
            "value_field": { "type": "string" },
            "valueField": { "type": "string" },
            "label_field": { "type": "string" },
            "labelField": { "type": "string" },
            "only_selected": { "type": "boolean" },
            "onlySelected": { "type": "boolean" },
            "selected_only": { "type": "boolean" },
            "selectedOnly": { "type": "boolean" },
            "search": { "type": "boolean" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "condition": { "$ref": "condition-v3.schema.json" }
  }
}
