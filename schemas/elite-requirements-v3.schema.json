{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg-db.local/schemas/elite-requirements-v3.schema.json",
  "title": "Elite Requirements V3",
  "description": "Canonical staged elite requirement profile.",
  "type": "object",
  "required": ["total_xp", "stages"],
  "properties": {
    "total_xp": { "type": "number" },
    "stages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kind"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "enum": ["primary", "specific_choice", "tag_pool", "optional_pool", "named_count"] },
          "min_xp": { "type": "number" },
          "min_count": { "type": "number" },
          "entry_type": { "type": "string" },
          "field": { "type": "string" },
          "values": { "type": "array", "items": { "type": "string" } },
          "names": { "type": "array", "items": { "type": "string" } },
          "allowed_entry_types": { "type": "array", "items": { "type": "string" } },
          "options": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { "type": "string" },
                "name": { "type": "string" }
              },
              "required": ["name"],
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
