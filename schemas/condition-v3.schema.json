{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg-db.local/schemas/condition-v3.schema.json",
  "title": "Condition V3",
  "description": "Canonical `when` condition tree for catalog schema v3.",
  "oneOf": [
    {
      "type": "object",
      "required": ["field", "op"],
      "additionalProperties": false,
      "properties": {
        "field": {
          "type": "string",
          "description": "Documented canonical field path such as `selected.names` or `selected.levels.by_name.Robust`."
        },
        "op": {
          "type": "string",
          "enum": ["exists", "equals", "not_equals", "includes", "includes_any", "includes_all", "gt", "gte", "lt", "lte"]
        },
        "value": {}
      }
    },
    {
      "type": "object",
      "required": ["all"],
      "additionalProperties": false,
      "properties": {
        "all": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "condition-v3.schema.json" }
        }
      }
    },
    {
      "type": "object",
      "required": ["any"],
      "additionalProperties": false,
      "properties": {
        "any": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "condition-v3.schema.json" }
        }
      }
    },
    {
      "type": "object",
      "required": ["not"],
      "additionalProperties": false,
      "properties": {
        "not": { "$ref": "condition-v3.schema.json" }
      }
    }
  ]
}
