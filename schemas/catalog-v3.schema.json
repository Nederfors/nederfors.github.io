{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg-db.local/schemas/catalog-v3.schema.json",
  "title": "Catalog V3",
  "description": "Canonical English gameplay catalog schema for authored data files.",
  "type": "object",
  "required": ["schema_version", "entries"],
  "properties": {
    "schema_version": {
      "const": 3
    },
    "type_rules": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "tags": {
            "type": "object",
            "properties": {
              "types": { "oneOf": [{ "type": "string" }, { "type": "array", "items": { "type": "string" } }] },
              "traditions": { "oneOf": [{ "type": "string" }, { "type": "array", "items": { "type": "string" } }] },
              "tests": { "oneOf": [{ "type": "string" }, { "type": "array", "items": { "type": "string" } }] },
              "qualities": { "oneOf": [{ "type": "string" }, { "type": "array", "items": { "type": "string" } }] },
              "max_count": { "type": "number" },
              "hidden": { "type": "boolean" },
              "race": { "oneOf": [{ "type": "string" }, { "type": "array", "items": { "type": "string" } }] },
              "artifact_binding": { "type": "object" },
              "xp": { "type": "number" },
              "inventory": { "type": "boolean" }
            },
            "additionalProperties": true
          },
          "levels": {
            "type": "object",
            "additionalProperties": {
              "oneOf": [
                { "type": "string" },
                {
                  "type": "object",
                  "properties": {
                    "description": { "type": "string" },
                    "actions": {
                      "oneOf": [
                        { "type": "string" },
                        { "type": "array", "items": { "type": "string" } }
                      ]
                    },
                    "tests": {
                      "oneOf": [
                        { "type": "string" },
                        { "type": "array", "items": { "type": "string" } }
                      ]
                    },
                    "damage_type": { "type": "string" },
                    "xp": { "type": "number" },
                    "rules": {
                      "type": "object",
                      "properties": {
                        "modify": { "type": "array", "items": { "$ref": "rule-v3.schema.json#/definitions/modifyRule" } },
                        "require": { "type": "array", "items": { "$ref": "rule-v3.schema.json#/definitions/requireRule" } },
                        "conflict": { "type": "array", "items": { "$ref": "rule-v3.schema.json#/definitions/conflictRule" } },
                        "grant": { "type": "array", "items": { "$ref": "rule-v3.schema.json#/definitions/grantRule" } },
                        "choice": { "type": "array", "items": { "$ref": "rule-v3.schema.json#/definitions/choiceRule" } }
                      },
                      "additionalProperties": true
                    }
                  },
                  "additionalProperties": true
                }
              ]
            }
          },
          "rules": {
            "type": "object",
            "properties": {
              "modify": { "type": "array", "items": { "$ref": "rule-v3.schema.json#/definitions/modifyRule" } },
              "require": { "type": "array", "items": { "$ref": "rule-v3.schema.json#/definitions/requireRule" } },
              "conflict": { "type": "array", "items": { "$ref": "rule-v3.schema.json#/definitions/conflictRule" } },
              "grant": { "type": "array", "items": { "$ref": "rule-v3.schema.json#/definitions/grantRule" } },
              "choice": { "type": "array", "items": { "$ref": "rule-v3.schema.json#/definitions/choiceRule" } }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": false
      }
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "tags"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "tags": { "type": "object" },
          "levels": { "type": "object" },
          "rules": { "type": "object" },
          "elite_requirements": { "$ref": "elite-requirements-v3.schema.json" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
