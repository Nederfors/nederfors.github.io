{
  "name": "symbapedia-app",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config ./vite.config.js",
    "build": "vite build --config ./vite.config.js",
    "preview": "vite preview --config ./vite.config.js",
    "test:e2e": "npm run build && playwright test --config=./playwright.config.js",
    "test:lighthouse": "npm run build && node ./scripts/run-lighthouse.mjs",
    "test:scenarios": "npm run build && node ./scripts/run-scenario-metrics.mjs",
    "test:perf": "npm run build && node ./scripts/run-perf-baseline.mjs"
  },
  "dependencies": {
    "comlink": "^4.4.2",
    "dexie": "^4.2.0",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.2",
    "lighthouse": "^12.0.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0"
  }
}
