{
  "name": "symbapedia-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build:legacy": "node ./scripts/build_legacy_bundles.mjs",
    "icons:pwa": "node ./scripts/generate_pwa_icons.mjs",
    "sync:static": "python3 ./scripts/sync_static_assets.py",
    "dev": "vite --config ./vite.config.js",
    "server:start": "node ./server/start.js",
    "db:generate": "drizzle-kit generate --config ./drizzle.config.js",
    "db:check": "drizzle-kit check --config ./drizzle.config.js",
    "db:migrate": "node ./server/db/migrate.js",
    "prebuild": "npm run icons:pwa && python3 ./scripts/build_offline_manifest.py && npm run sync:static && npm run build:legacy",
    "build": "vite build --config ./vite.config.js",
    "build:analyze": "npm run build -- --mode analyze",
    "preview": "vite preview --config ./vite.config.js",
    "lint": "eslint . --max-warnings=0",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "validate:data": "python3 scripts/build_all.py --strict --check && node scripts/validate_catalog_schemas.mjs && node scripts/migrate_catalog_schema.mjs --check",
    "verify:rules": "node scripts/verify_rules_helper.js",
    "test:unit": "vitest run --config ./vitest.config.js",
    "test:unit:watch": "vitest --config ./vitest.config.js",
    "test:server:integration": "vitest run --config ./vitest.config.js tests/server/migration.integration.test.js",
    "test:e2e": "npm run build && playwright test --config=./playwright.config.js",
    "test:e2e:core": "playwright test --config=./playwright.release.config.js --project=chromium --project=webkit --workers=2",
    "test:e2e:responsive": "playwright test --config=./playwright.release.config.js --project='Mobile Chrome' --project='Mobile Safari' --workers=1",
    "test:e2e:pwa": "playwright test --config=./playwright.release.config.js --project=chromium-pwa --workers=1",
    "test:interaction-budget": "npm run build && playwright test tests/performance-budget.spec.js --config=./playwright.config.js --project=chromium --workers=1",
    "test:lighthouse": "npm run build && node ./scripts/run-lighthouse.mjs",
    "test:online-perf": "node ./scripts/run-online-perf.mjs",
    "test:scenarios": "npm run build && node ./scripts/run-scenario-metrics.mjs",
    "test:perf": "npm run build && node ./scripts/run-perf-baseline.mjs",
    "smoke:production": "node ./scripts/run-production-smoke.mjs"
  },
  "dependencies": {
    "comlink": "^4.4.2",
    "daub-ui": "^3.19.6",
    "dexie": "^4.2.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.10.0",
    "jszip": "^3.10.1",
    "pg": "^8.22.0",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.2",
    "ajv": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.1.0",
    "lighthouse": "^12.0.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.35.3",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.0"
  }
}
